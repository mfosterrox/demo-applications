# Copy to quay.env and customize, then: source quay.env && ./build-images.sh
#
# Quay robot account or user with push access to the repositories below.

QUAY_REGISTRY=quay.io
TEAM_NAME=mfoster
VERSION=0.1.0

# Optional: login before PUSH=1
# export QUAY_USER=your-robot-account
# export QUAY_TOKEN=your-token
# podman login "$QUAY_REGISTRY" -u "$QUAY_USER" -p "$QUAY_TOKEN"
